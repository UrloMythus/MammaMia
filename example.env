# This env variable is mandatory 
# Questa variabile è obbligatoria
TMDB_KEY= "INSERT YOUR API KEY HERE"
# Those env variable are not mandatory
# Queste variabili non sono obbligatoria
PROXY = ["PROXY1","PROXY2"]
FORWARDPROXY = "YOURFORWARDPROXY/"

# Optional: CF Worker that auto-solves the uprot.net captcha and returns
# resolved MaxStream URLs (KV-cached cookies + hourly refresh cron).
# When set, bypass_uprot falls back to it if the local uprot.txt cookies
# are missing or stale, so users no longer have to visit /uprot manually.
# Architecture: https://github.com/Pieropapamonello/nello-stream/blob/master/MAMMAMIA_MAXSTREAM_INTEGRATION.md
CF_UPROT_WORKER_URL = ""
CF_UPROT_WORKER_AUTH = ""